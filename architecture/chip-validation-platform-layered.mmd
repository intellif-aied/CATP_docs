flowchart TB
  %% Layered architecture for chip software validation automation platform.
  %% Read from bottom to top: resources -> components -> management -> agents -> presentation.

  subgraph L5["第五层：展示与协同层"]
    DASH["Dashboard<br/>资源利用率 / 执行进度 / 失败趋势 / 投片准入"]
    WORKBENCH["验证工作台<br/>需求 / 用例 / 计划 / 任务 / Issue / PR"]
    AGENT_STUDIO["Agent Studio<br/>Agent 编排 / MCP 可视化 / Skill 可插拔 / Subagent 拓扑"]
    REPORT_VIEW["报告与通知<br/>日报 / 周报 / 里程碑报告 / 风险提醒"]
  end

  subgraph L4["第四层：Agent 层"]
    SCHED_AGENT["资源调度 Agent<br/>资源选择 / 抢占 / 预约 / 夜间填充"]
    CASE_AGENT["用例选择 Agent<br/>冒烟 / 全量 / 增量 / 风险回归"]
    EXEC_AGENT["执行 Agent<br/>环境部署 / 用例执行 / 结果采集"]
    FAIL_AGENT["失败分析 Agent<br/>日志解析 / 失败归因 / 聚类"]
    RERUN_AGENT["复跑 Agent<br/>同平台复跑 / 换资源复跑 / 跨平台复跑"]
    DEBUG_AGENT["问题定位 Agent<br/>Trace / 二分 / 最小复现 / 现场保护"]
    REPORT_AGENT["报告 Agent<br/>资源利用率 / 失败趋势 / 风险 Top"]
    PR_AGENT["变更影响 Agent<br/>PR 影响面 / 修复验证 / 准入建议"]
  end

  subgraph L3["第三层：管理模块与规则编排层"]
    REQ["需求管理"]
    CASE["用例管理"]
    RES_MGMT["资源管理"]
    MILESTONE["里程碑管理"]
    PLAN["执行计划管理"]
    TASK["执行任务管理"]
    ISSUE["Issue 管理"]
    PR["PR 管理"]
    RULE["规则引擎<br/>准入规则 / 调度策略 / 复跑策略 / 风险策略"]
    WORKFLOW["事件驱动与流程编排<br/>事件总线 / 状态机 / DAG / SLA / 补偿"]
  end

  subgraph L2["第二层：平台组件与能力层"]
    K8S["K8s / Worker Runtime<br/>Job / Pod / Cron / HPA"]
    LOG["Log Pipeline<br/>执行日志 / 系统日志 / Agent Trace"]
    MCP["MCP 组件<br/>Server Registry / Tool Gateway / 权限"]
    SKILL["Skill 组件<br/>Skill 包 / 版本 / 参数 / 发布"]
    SUBAGENT["Subagent 组件<br/>角色模板 / 上下文隔离 / 协作拓扑"]
    ARTIFACT["Artifacts 组件<br/>日志 / Trace / Dump / Report / 复现脚本"]
    QUEUE["Queue / Lock<br/>任务队列 / 资源锁 / 幂等 / 去重"]
    OBS["Observability<br/>Metrics / Audit / Cost / Quality"]
  end

  subgraph L1["第一层：基础资源与存储层"]
    SQL["SQL DB<br/>业务元数据 / 状态 / 关系"]
    S3["S3 / MinIO<br/>大文件 / 日志 / Artifact"]
    REDIS["Redis<br/>队列缓存 / 锁 / 心跳"]
    EMU["EMU 资源池"]
    FPGA["FPGA 资源池"]
    CPU["CPU Farm"]
    QEMU["QEMU + cmodel / amodel"]
    GIT["Git Repo / CI 产物<br/>PR / Commit / Build / Binary"]
  end

  L1 --> L2
  L2 --> L3
  L3 --> L4
  L4 --> L5

  SQL --> REQ
  SQL --> CASE
  SQL --> PLAN
  SQL --> TASK
  S3 --> ARTIFACT
  REDIS --> QUEUE
  EMU --> RES_MGMT
  FPGA --> RES_MGMT
  CPU --> RES_MGMT
  QEMU --> RES_MGMT
  GIT --> PR

  ARTIFACT --> LOG
  LOG --> FAIL_AGENT
  MCP --> SCHED_AGENT
  MCP --> EXEC_AGENT
  SKILL --> FAIL_AGENT
  SKILL --> DEBUG_AGENT
  SUBAGENT --> AGENT_STUDIO
  QUEUE --> WORKFLOW
  OBS --> DASH

  RULE --> SCHED_AGENT
  RULE --> CASE_AGENT
  WORKFLOW --> EXEC_AGENT
  WORKFLOW --> RERUN_AGENT
  WORKFLOW --> DEBUG_AGENT
  TASK --> EXEC_AGENT
  ISSUE --> FAIL_AGENT
  PR --> PR_AGENT
  MILESTONE --> REPORT_AGENT

  classDef l1 fill:#eef2ff,stroke:#4f46e5,color:#1e1b4b;
  classDef l2 fill:#ecfeff,stroke:#0891b2,color:#164e63;
  classDef l3 fill:#f0fdf4,stroke:#16a34a,color:#14532d;
  classDef l4 fill:#fff7ed,stroke:#ea580c,color:#7c2d12;
  classDef l5 fill:#fdf2f8,stroke:#db2777,color:#831843;

  class SQL,S3,REDIS,EMU,FPGA,CPU,QEMU,GIT l1;
  class K8S,LOG,MCP,SKILL,SUBAGENT,ARTIFACT,QUEUE,OBS l2;
  class REQ,CASE,RES_MGMT,MILESTONE,PLAN,TASK,ISSUE,PR,RULE,WORKFLOW l3;
  class SCHED_AGENT,CASE_AGENT,EXEC_AGENT,FAIL_AGENT,RERUN_AGENT,DEBUG_AGENT,REPORT_AGENT,PR_AGENT l4;
  class DASH,WORKBENCH,AGENT_STUDIO,REPORT_VIEW l5;
